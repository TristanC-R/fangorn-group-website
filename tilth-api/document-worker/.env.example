# Document Vault Python worker — copy to `.env` in this folder (optional)
# or rely on `tilth-api/.env` (loaded first; values here override if present).

# Required (same as Node API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional — OpenAI embeddings (omit to use deterministic local-hash embeddings)
OPENAI_API_KEY=
DOCUMENT_VAULT_EMBEDDING_MODEL=text-embedding-3-small
DOCUMENT_VAULT_CHAT_MODEL=gpt-4o-mini

# Optional — Neo4j graph mirror
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
# Alias supported by graph loader:
# NEO4J_USER=

# Optional — worker tuning
DOCUMENT_VAULT_WORKER_ID=doc-worker-local
DOCUMENT_VAULT_POLL_SECONDS=5
DOCUMENT_VAULT_LEASE_MINUTES=15
DOCUMENT_VAULT_BUCKET=farm-documents
DOCUMENT_VAULT_PROCESSING_VERSION=docling-v1
DOCUMENT_VAULT_EMBEDDING_BATCH_SIZE=32
