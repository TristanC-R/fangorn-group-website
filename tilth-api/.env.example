# Port for the HTTP server (default 3847)
PORT=3847

# Comma-separated browser origins allowed to call this API (your Vite dev URL + production site)
CORS_ORIGINS=http://localhost:5173,https://fangorn.earth

# Required for OSM usage policies: reachable contact email
OSM_CONTACT_EMAIL=you@example.com

# Optional: full User-Agent string (otherwise built from OSM_CONTACT_EMAIL)
# OSM_USER_AGENT=FangornTilthApi/1.0 (https://example.com/contact)

# Upstream defaults are fine for most installs
# OVERPASS_URL=https://overpass-api.de/api/interpreter
# NOMINATIM_URL=https://nominatim.openstreetmap.org

# --- Per-field × per-layer extraction (tilth_field_layer_data) ---
# Required for the extractor to write results to Supabase. Get the service-role
# key from the Supabase dashboard → Project Settings → API. It bypasses RLS so
# the extractor can write derived data on behalf of any owner. Keep secret.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...

# Concurrency for the background extractor. Each unit roughly = one upstream
# fetch in flight. UK upstreams (BGS, Defra/EA) tolerate 4–8 fine; lower if
# you start seeing 429s in the log.
# TILTH_EXTRACT_CONCURRENCY=4

# Override the per-field render resolution for raster trace (BGS/UKSO).
# Default is 1024 px per axis (capped). Higher = sharper class boundaries
# but slower extraction and bigger GeoJSON.
# TILTH_TRACE_RESOLUTION_PX=1024

# --- Market prices ---
# MARKET_PROVIDER=public uses reference/public source checks unless MARKET_API_URL is set.
# Point MARKET_API_URL at a paid or private JSON feed returning either an array of
# rows or { rows: [...] }. Rows can include id, market, commodity, price, unit,
# currency, basis, region, source, sourceUrl, updatedAt, trend, confidence, stale.
# MARKET_PROVIDER=public
# MARKET_API_URL=https://example.com/farm-market-prices.json
# MARKET_API_KEY=
# MARKET_CACHE_TTL_MS=900000

# --- Google Calendar sync ---
# Create an OAuth client in Google Cloud and add the redirect URL below to its
# authorised redirect URIs. The app redirect should point back to the Tilth UI.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALENDAR_REDIRECT_URL=http://localhost:3847/api/calendar/google/callback
# GOOGLE_CALENDAR_APP_REDIRECT_URL=http://localhost:5173/tilth/calendar
# GOOGLE_CALENDAR_TIMEZONE=Europe/London

# --- Document Vault ---
# Optional OpenAI credentials for document embeddings/chat/report drafting. Without
# OPENAI_API_KEY, the API and worker use deterministic local hash embeddings so
# local plumbing can still be tested.
# OPENAI_API_KEY=
# DOCUMENT_VAULT_EMBEDDING_MODEL=text-embedding-3-small
# DOCUMENT_VAULT_CHAT_MODEL=gpt-4o-mini
# DOCUMENT_VAULT_MAX_JSON_UPLOAD_BYTES=26214400

# Optional shared Neo4j Community/free database for graph loading. The worker
# stores every tenant-owned node/relationship with farm_id; do not expose these
# values to the frontend.
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=

# Python worker tuning. Run from tilth-api/document-worker with:
# python worker.py
# DOCUMENT_VAULT_WORKER_ID=doc-worker-local
# DOCUMENT_VAULT_POLL_SECONDS=5
# DOCUMENT_VAULT_LEASE_MINUTES=15
