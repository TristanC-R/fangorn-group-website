# Supabase (required)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: override OAuth redirect (otherwise uses window.location.origin)
# VITE_SUPABASE_REDIRECT_TO=http://localhost:5173

# Tilth: optional small Node backend on your PC (Nominatim + Overpass with proper User-Agent / email)
# npm run tilth-api — see tilth-api/README.md
# VITE_TILTH_API_URL=http://192.168.1.10:3847

# If you do NOT use VITE_TILTH_API_URL: Nominatim from the browser (add contact email per OSM policy)
# https://operations.osmfoundation.org/policies/nominatim/
# VITE_NOMINATIM_CONTACT_EMAIL=you@example.com

